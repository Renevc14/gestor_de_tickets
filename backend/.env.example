# ============================================================
# TicketFlow — Variables de entorno (EJEMPLO)
# Copiar a .env y completar los valores reales
# ============================================================

# ─── Base de datos (PostgreSQL) ──────────────────────────────
# Desarrollo local
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/ticketflow_dev"

# Railway (producción) — se obtiene desde el dashboard de Railway
# DATABASE_URL="postgresql://postgres:RAILWAY_PASSWORD@HOST:PORT/railway"

# ─── JWT y Seguridad ─────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_64_characters_minimum
REFRESH_TOKEN_SECRET=your_refresh_token_secret_64_characters_minimum
ENCRYPTION_KEY=your_encryption_key_64_hex_characters

# ─── Aplicación ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── MFA ─────────────────────────────────────────────────────
MFA_ISSUER=TicketFlow

# ─── Email (opcional — notificaciones al asignar y cambiar estado) ───────────
# Si no se configura, las notificaciones se omiten silenciosamente
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail
SMTP_FROM=TicketFlow <tu_email@gmail.com>

# ─── Contraseñas del seed inicial ────────────────────────────
ADMIN_PASSWORD=Admin@TicketFlow2025!
TECNICO_PASSWORD=Tecnico@TicketFlow2025!
